# Nothing here is required — BugPilot defaults to Demo mode (no AI, no key).
# Set AI_PROVIDER to change the server-side default. Users can also override
# the provider per-browser from the in-app settings panel (BYOK).

AI_PROVIDER=demo

# --- Claude (Anthropic) ---
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Gemini (Google — genuinely free tier) ---
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (local, free, no key) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
